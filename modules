def html_table(rows, max_cols=12):
    if not rows:
        return "<p>No records.</p>"
    keys = list(rows[0].keys())[:max_cols]
    html = "<table><tr>" + "".join(f"<th>{k}</th>" for k in keys) + "</tr>"
    for r in rows:
        html += "<tr>" + "".join(f"<td>{str(r.get(k,''))[:160]}</td>" for k in keys) + "</tr>"
    return html + "</table>"


