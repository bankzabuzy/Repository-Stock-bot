    cols = list(rows[0].keys())[:10]
    html = "<table border='1' cellpadding='6' cellspacing='0'><tr>" + "".join(f"<th>{c}</th>" for c in cols) + "</tr>"
    for r in rows:
        html += "<tr>" + "".join(f"<td>{str(r.get(c, ''))[:180]}</td>" for c in cols) + "</tr>"
    return html + "</table>"


