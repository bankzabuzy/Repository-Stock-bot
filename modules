def rows_to_dicts(rows):
    return [dict(r) for r in rows or []]


def execute(sql, params=(), fetch=None):
    c = conn()
    try:
        cur = c.execute(sql, params)
        if fetch == "one":
            row = cur.fetchone()
            return dict(row) if row else None
        if fetch == "all":
            return rows_to_dicts(cur.fetchall())
        c.commit()
        return cur.lastrowid
    finally:
        c.close()


